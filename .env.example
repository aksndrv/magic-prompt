# Copy this to .env (or set these in your hosting provider's dashboard).
# Never commit the real values.

PORT=3000

# From patreon.com/portal/registration/register-clients
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
# Must exactly match the redirect URI you register with Patreon,
# and must be your real deployed URL, e.g. https://nl2ae.onrender.com/auth/patreon/callback
PATREON_REDIRECT_URI=
# Find this in your Patreon creator dashboard under campaign settings/URL
PATREON_CAMPAIGN_ID=
# Set when you create the webhook at patreon.com/portal/registration/register-webhooks
PATREON_WEBHOOK_SECRET=

# console.anthropic.com -- this is YOUR key, spent on behalf of all patrons
ANTHROPIC_API_KEY=

# Minimum pledge (in cents) that counts as "qualifying" -- 500 = $5.00
MIN_PLEDGE_CENTS=500

# Hard monthly spend cap per patron, in cents -- 250 = $2.50
# (leaves margin under the ~$3.44 you said you net per member after Patreon fees)
MONTHLY_BUDGET_CENTS=250
